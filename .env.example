# ========================================
# Eeuwig Dichtbij — Omgevingsvariabelen
# ========================================
# Kopieer dit bestand naar .env en vul de waarden in.
# NOOIT .env toevoegen aan git (staat al in .gitignore).

# ---- bol.com Retailer API ----
# Aanmaken via: Verkopers Dashboard > Instellingen > API-instellingen
BOL_CLIENT_ID=jouw_client_id_hier
BOL_CLIENT_SECRET=jouw_client_secret_hier

# Zet op 'true' om de bol.com demo-omgeving te gebruiken (geen echte transacties)
BOL_DEMO_MODE=true

# ---- Server ----
PORT=3001
FRONTEND_URL=http://localhost:5173

# ---- Admin beveiliging ----
# Stel een sterk wachtwoord in voor toegang tot de beheerAPI
ADMIN_API_KEY=verander_dit_naar_een_sterk_wachtwoord
