# ========================================
# Eeuwig Hart — Omgevingsvariabelen
# ========================================
# Kopieer dit bestand naar .env en vul de waarden in.
# NOOIT .env toevoegen aan git (staat al in .gitignore).

# ---- Server ----
PORT=3001
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:3001

# ---- Productie (zet deze op je hostingserver) ----
# FRONTEND_URL=https://eeuwighart.nl
# SERVER_URL=https://api.eeuwighart.nl
# VITE_API_URL=https://api.eeuwighart.nl

# ---- Admin beveiliging ----
# Genereer ADMIN_API_KEY:   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Genereer JWT_SECRET:      node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Genereer wachtwoordhash:  node -e "require('bcryptjs').hash('JOUW_WACHTWOORD',12).then(console.log)"
ADMIN_API_KEY=verander_dit_naar_een_sterk_wachtwoord
ADMIN_USERNAME=beheerder
ADMIN_PASSWORD_HASH=$2b$12$...bcrypt_hash_hier...
JWT_SECRET=minimaal_32_tekens_willekeurig

# ---- bol.com Retailer API ----
# Account: https://verkopen.bol.com
# Keys aanmaken via: Verkopers Dashboard > Instellingen > API-instellingen
BOL_CLIENT_ID=jouw_client_id_hier
BOL_CLIENT_SECRET=jouw_client_secret_hier
# Zet op 'false' voor echte transacties in productie
BOL_DEMO_MODE=true

# ---- iCEPAY Betaalgateway ----
# Account aanmaken via: https://www.icepay.com/nl/
# Merchant ID en Secret vind je in: iCEPAY Dashboard > Instellingen
ICEPAY_MERCHANT_ID=jouw_merchant_id_hier
ICEPAY_MERCHANT_SECRET=jouw_merchant_secret_hier

# ---- MyParcel (verzending) ----
# Account aanmaken via: https://www.myparcel.nl/
# API key aanmaken via: MyParcel Dashboard > Instellingen > API
MYPARCEL_API_KEY=jouw_api_key_hier

# ---- Resend (e-mail) ----
# Account aanmaken via: https://resend.com
# 1. Maak een API key aan: Resend Dashboard > API Keys > Create API Key
# 2. Verifieer je domein: Resend Dashboard > Domains > Add Domain (eeuwighart.nl)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=info@eeuwighart.nl

# ---- Google Places API (reviews) ----
# Google Cloud Console: https://console.cloud.google.com
# 1. Maak een project aan en activeer "Places API"
# 2. Maak een API key aan: Credentials > Create Credentials > API Key
#    (beperk deze key tot Places API voor veiligheid)
# 3. Zoek je Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
GOOGLE_PLACES_API_KEY=jouw_google_places_api_key_hier
GOOGLE_PLACE_ID=jouw_google_place_id_hier

# ---- Supabase (database) ----
# Project aanmaken via: https://supabase.com/dashboard > New Project
# Keys vinden via: Project Settings > API
SUPABASE_URL=https://jouwproject.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
